# Пароль входа в веб-интерфейс (Vercel)
NAS_PASSWORD=your_web_password

# Секрет для запросов к API на Pi (то же значение, что и NAS_SECRET на Pi)
NAS_SECRET=your_shared_api_secret

# Секрет для регистрации туннеля (то же, что NAS_REGISTER_SECRET на Pi)
NAS_REGISTER_SECRET=your_register_secret

# Vercel KV — создаётся в Vercel при подключении KV Storage
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
